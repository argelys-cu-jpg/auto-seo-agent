generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WorkflowState {
  discovered
  scored
  queued
  outline_generated
  draft_generated
  in_review
  revision_requested
  approved
  published
  monitoring
  refresh_recommended
  refreshed
}

enum RecommendationType {
  write_now
  monitor
  refresh_existing
  support_cluster
  merge_or_decannibalize
  skip
}

enum ApprovalDecision {
  approve
  request_revision
  reject
}

enum PublicationStatus {
  draft
  pending_publish
  published
  unpublished
  sync_error
}

enum OpportunityPath {
  blog
  landing_page
}

enum OpportunityType {
  keyword
  page_idea
  competitor_page
  lp_optimization
}

enum RowStatus {
  idle
  running
  blocked
  needs_review
  approved
  published
  failed
}

enum WorkflowStepName {
  discovery
  prioritization
  brief
  draft
  qa
  publish
}

enum WorkflowStepStatus {
  not_started
  running
  completed
  failed
  needs_review
  approved
}

model Keyword {
  id              String   @id @default(cuid())
  term            String
  normalizedTerm  String   @unique
  source          String
  searchVolume    Int      @default(0)
  keywordDifficulty Int    @default(0)
  trendVelocity   Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  topicCandidates TopicCandidate[]
}

model TopicCandidate {
  id                    String             @id @default(cuid())
  keywordId             String?
  keyword               Keyword?           @relation(fields: [keywordId], references: [id])
  title                 String
  normalizedKeyword     String             @unique
  source                String
  workflowState         WorkflowState      @default(discovered)
  recommendation        RecommendationType @default(monitor)
  totalScore            Float              @default(0)
  scoreBreakdownJson    Json
  rationale             String
  businessValueNotes    String?
  cannibalizationRisk   Float              @default(0)
  topicType             String             @default("new_article")
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  briefs                ContentBrief[]
  outlines              Outline[]
  drafts                Draft[]
  approvals             Approval[]
  publications          Publication[]
  optimizationTasks     OptimizationRecommendation[]
  clusterMemberships    ContentClusterMember[]
  opportunities         Opportunity[]
}

model ContentBrief {
  id                 String   @id @default(cuid())
  topicCandidateId   String
  topicCandidate     TopicCandidate @relation(fields: [topicCandidateId], references: [id])
  promptVersionId    String?
  primaryKeyword     String
  secondaryKeywordsJson Json
  briefJson          Json
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  drafts             Draft[]
}

model Outline {
  id               String   @id @default(cuid())
  topicCandidateId String
  topicCandidate   TopicCandidate @relation(fields: [topicCandidateId], references: [id])
  outlineJson      Json
  promptVersionId  String?
  createdAt        DateTime @default(now())
}

model Draft {
  id               String   @id @default(cuid())
  topicCandidateId String
  topicCandidate   TopicCandidate @relation(fields: [topicCandidateId], references: [id])
  briefId          String?
  brief            ContentBrief? @relation(fields: [briefId], references: [id])
  promptVersionId  String?
  draftJson        Json
  html             String
  markdown         String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  approvals        Approval[]
  publications     Publication[]
}

model Approval {
  id               String           @id @default(cuid())
  topicCandidateId String
  topicCandidate   TopicCandidate   @relation(fields: [topicCandidateId], references: [id])
  draftId          String?
  draft            Draft?           @relation(fields: [draftId], references: [id])
  reviewerEmail    String
  decision         ApprovalDecision
  notes            String?
  createdAt        DateTime         @default(now())
}

model Publication {
  id               String            @id @default(cuid())
  topicCandidateId String
  topicCandidate   TopicCandidate    @relation(fields: [topicCandidateId], references: [id])
  draftId          String?
  draft            Draft?            @relation(fields: [draftId], references: [id])
  strapiEntryId    String?
  strapiDocumentId String?
  slug             String
  canonicalUrl     String?
  status           PublicationStatus @default(draft)
  metadataJson     Json
  fieldMappingJson Json?
  publishedAt      DateTime?
  updatedAt        DateTime          @updatedAt
  metricSnapshots  MetricSnapshot[]
  optimizationTasks OptimizationRecommendation[]
  publishResults   PublishResult[]
}

model Opportunity {
  id                  String         @id @default(cuid())
  keyword             String
  normalizedKeyword   String         @unique
  pageIdea            String?
  competitorPageUrl   String?
  intent              String
  path                OpportunityPath
  type                OpportunityType @default(keyword)
  rowStatus           RowStatus      @default(idle)
  lastError           String?
  topicCandidateId    String?
  topicCandidate      TopicCandidate? @relation(fields: [topicCandidateId], references: [id])
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  workflowRuns        WorkflowRun[]
  stepRuns            WorkflowStepRun[]
  revisionNotes       RevisionNote[]
  publishResults      PublishResult[]
}

model WorkflowRun {
  id                  String       @id @default(cuid())
  opportunityId       String
  opportunity         Opportunity  @relation(fields: [opportunityId], references: [id])
  status              RowStatus    @default(idle)
  trigger             String
  currentStep         WorkflowStepName?
  startedAt           DateTime     @default(now())
  completedAt         DateTime?
  error               String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  stepRuns            WorkflowStepRun[]
  publishResults      PublishResult[]
}

model WorkflowStepRun {
  id                  String             @id @default(cuid())
  opportunityId       String
  opportunity         Opportunity        @relation(fields: [opportunityId], references: [id])
  workflowRunId       String
  workflowRun         WorkflowRun        @relation(fields: [workflowRunId], references: [id])
  stepName            WorkflowStepName
  status              WorkflowStepStatus @default(not_started)
  version             Int                @default(1)
  inputJson           Json?
  outputJson          Json?
  manualOutputJson    Json?
  artifactType        String?
  artifactId          String?
  error               String?
  revisionNote        String?
  approvedBy          String?
  approvedAt          DateTime?
  startedAt           DateTime?
  completedAt         DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  revisionNotes       RevisionNote[]
  publishResults      PublishResult[]
}

model RevisionNote {
  id                  String          @id @default(cuid())
  opportunityId       String
  opportunity         Opportunity     @relation(fields: [opportunityId], references: [id])
  workflowStepRunId   String
  workflowStepRun     WorkflowStepRun @relation(fields: [workflowStepRunId], references: [id])
  note                String
  requestedBy         String
  createdAt           DateTime        @default(now())
}

model PublishResult {
  id                  String           @id @default(cuid())
  opportunityId       String
  opportunity         Opportunity      @relation(fields: [opportunityId], references: [id])
  workflowRunId       String?
  workflowRun         WorkflowRun?     @relation(fields: [workflowRunId], references: [id])
  workflowStepRunId   String?
  workflowStepRun     WorkflowStepRun? @relation(fields: [workflowStepRunId], references: [id])
  publicationId       String?
  publication         Publication?     @relation(fields: [publicationId], references: [id])
  status              String
  message             String?
  metadataJson        Json
  createdAt           DateTime         @default(now())
}

model MetricSnapshot {
  id             String   @id @default(cuid())
  publicationId  String
  publication    Publication @relation(fields: [publicationId], references: [id])
  capturedAt     DateTime @default(now())
  impressions    Int      @default(0)
  clicks         Int      @default(0)
  ctr            Float    @default(0)
  averagePosition Float   @default(0)
  conversions    Int      @default(0)
  metricsJson    Json
}

model OptimizationRecommendation {
  id             String   @id @default(cuid())
  topicCandidateId String?
  topicCandidate TopicCandidate? @relation(fields: [topicCandidateId], references: [id])
  publicationId  String
  publication    Publication @relation(fields: [publicationId], references: [id])
  type           String
  priority       String
  reason         String
  recommendationJson Json
  createdAt      DateTime @default(now())
}

model ContentCluster {
  id             String   @id @default(cuid())
  name           String
  pillarKeyword  String
  createdAt      DateTime @default(now())
  members        ContentClusterMember[]
}

model ContentClusterMember {
  id             String   @id @default(cuid())
  clusterId      String
  cluster        ContentCluster @relation(fields: [clusterId], references: [id])
  topicCandidateId String
  topicCandidate TopicCandidate @relation(fields: [topicCandidateId], references: [id])
  role           String
}

model InternalLinkRecommendation {
  id               String   @id @default(cuid())
  sourceTopicId    String
  targetTopicId    String?
  sourceUrl        String?
  targetUrl        String?
  anchorText       String
  rationale        String
  confidence       Float    @default(0)
  createdAt        DateTime @default(now())
}

model AuditLog {
  id             String   @id @default(cuid())
  entityType     String
  entityId       String
  action         String
  actorType      String
  actorId        String?
  payload        Json
  createdAt      DateTime @default(now())
}

model JobRun {
  id             String   @id @default(cuid())
  jobType        String
  status         String
  idempotencyKey String   @unique
  payload        Json
  result         Json?
  error          String?
  startedAt      DateTime @default(now())
  finishedAt     DateTime?
}

model PromptVersion {
  id          String   @id @default(cuid())
  templateId  String
  version     String
  systemText  String
  userText    String
  createdAt   DateTime @default(now())
}
