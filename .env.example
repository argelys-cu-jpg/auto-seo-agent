NODE_ENV=development
APP_MODE=mock
ADMIN_EMAIL=reviewer@cookunity.local
ADMIN_PASSWORD=change-me
NEXT_PUBLIC_APP_NAME=CookUnity SEO Agent
NEXT_PUBLIC_BASE_URL=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cookunity_seo_agent
REDIS_URL=redis://localhost:6379
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
AHREFS_API_KEY=
AHREFS_BASE_URL=https://api.ahrefs.com
GSC_CLIENT_EMAIL=
GSC_PRIVATE_KEY=
GSC_SITE_URL=https://www.cookunity.com
GOOGLE_TRENDS_GEO=US
SERP_API_KEY=
SERP_PROVIDER=mock
STRAPI_BASE_URL=https://cms.example.com
STRAPI_API_TOKEN=
STRAPI_COLLECTION=blog-posts
STRAPI_DOCUMENT_ID_FIELD=documentId
STRAPI_ENTRY_ID_FIELD=id
STRAPI_FIELD_MAPPING_JSON={"title":"title","slug":"slug","excerpt":"excerpt","body":"body","seoTitle":"seo_title","metaDescription":"meta_description","schema":"schema_json","tags":"tags","category":"category","featuredImage":"featured_image","publishStatus":"publishedAt"}
ANALYTICS_PROVIDER=mock
ANALYTICS_API_KEY=
OTEL_EXPORTER_OTLP_ENDPOINT=
SLACK_ALERT_WEBHOOK=
PUBLISH_ENABLED=false
ENABLE_MOCK_DATA=true
DISCOVERY_CRON=*/30 * * * *
MONITORING_CRON=0 7 * * *
REFRESH_CRON=0 9 * * 1
